<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LocalLedger.ViewModels"
             xmlns:models="using:LocalLedger.Models"
             xmlns:views="using:LocalLedger.Views"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="LocalLedger.Views.LedgerView"
             x:DataType="vm:LedgerViewModel">

    <Design.DataContext>
        <vm:LedgerViewModel ShowAddForm="False" />
    </Design.DataContext>

    <Grid>
        <ScrollViewer Margin="16">
            <StackPanel Spacing="16">
                <!-- 预算提醒 -->
                <Border Background="#FEF2F2" CornerRadius="8" Padding="12"
                        IsVisible="{Binding IsBudgetOver}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Warning" FontSize="16" Foreground="#DC2626" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Text="本月支出已超出预算！" FontSize="14" Foreground="#DC2626" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Background="#FFFBEB" CornerRadius="8" Padding="12"
                        IsVisible="{Binding IsBudgetNear}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Alert" FontSize="16" Foreground="#D97706" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Text="本月支出即将达到预算上限" FontSize="14" Foreground="#D97706" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12" Padding="16"
                        IsVisible="{Binding BudgetLimit, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="预算进度" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N0} / {1:N0} 元">
                                        <Binding Path="CurrentMonthExpense" />
                                        <Binding Path="BudgetLimit" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <ProgressBar Value="{Binding BudgetPercentage}" Maximum="100" Height="8" Margin="0,8,0,0"
                                     Foreground="{Binding IsBudgetOver, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Budget}" />
                        <TextBlock Text="{Binding BudgetPercentage, StringFormat='{}{0:F1}%'}" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="概览" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                            <Border Grid.Column="0" Grid.Row="0" Background="#10B981" CornerRadius="12"
                                    Padding="16" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="收入" Foreground="White" FontSize="13" />
                                    <TextBlock Text="{Binding TotalIncome, StringFormat='+{0:0.00}'}"
                                               Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Grid.Row="0" Background="#EF4444" CornerRadius="12"
                                    Padding="16" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="支出" Foreground="White" FontSize="13" />
                                    <TextBlock Text="{Binding TotalExpense, StringFormat='-{0:0.00}'}"
                                               Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <TextBlock Text="结余: " FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding Balance}" FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="8">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <RadioButton Content="全部" GroupName="DateFilter"
                                     CommandParameter="{x:Static vm:DateFilter.All}"
                                     IsChecked="{Binding CurrentFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static vm:DateFilter.All}}" />
                        <RadioButton Content="今天" GroupName="DateFilter"
                                     CommandParameter="{x:Static vm:DateFilter.Today}"
                                     IsChecked="{Binding CurrentFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static vm:DateFilter.Today}}" />
                        <RadioButton Content="本周" GroupName="DateFilter"
                                     CommandParameter="{x:Static vm:DateFilter.ThisWeek}"
                                     IsChecked="{Binding CurrentFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static vm:DateFilter.ThisWeek}}" />
                        <RadioButton Content="本月" GroupName="DateFilter"
                                     CommandParameter="{x:Static vm:DateFilter.ThisMonth}"
                                     IsChecked="{Binding CurrentFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter={x:Static vm:DateFilter.ThisMonth}}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="记录" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" />
                <ItemsControl ItemsSource="{Binding FilteredTransactions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Transaction">
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                                            Background="{Binding Type, Converter={StaticResource TypeToColorConverter}}"
                                            VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock
                                            Text="{Binding Category, Converter={StaticResource FirstCharConverter}}"
                                            Foreground="White" FontSize="16" FontWeight="Bold"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Category}" FontSize="15" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayAmount}"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{Binding Type, Converter={StaticResource TypeToColorConverter}}" />
                                        <Button
                                            Command="{Binding $parent[UserControl].DataContext.EditTransactionCommand}"
                                            CommandParameter="{Binding}"
                                            Margin="8,0,4,0"
                                            Background="Transparent"
                                            Padding="8,4">
                                            <ui:FASymbolIcon Symbol="Edit" />
                                        </Button>
                                        <Button
                                            Command="{Binding $parent[UserControl].DataContext.DeleteTransactionCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            Padding="8,4">
                                            <ui:FASymbolIcon Symbol="Delete" Foreground="#EF4444" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="暂无记录" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,20,0,0"
                           IsVisible="{Binding !FilteredTransactions.Count}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24"
                    Spacing="12">
            <Button Width="56" Height="56" CornerRadius="28"
                    Background="#10B981" Command="{Binding ShowAddIncomeCommand}"
                    ToolTip.Tip="记收入">
                <TextBlock Text="+" FontSize="28" Foreground="White" FontWeight="Bold" />
            </Button>
            <Button Width="56" Height="56" CornerRadius="28"
                    Background="#EF4444" Command="{Binding ShowAddExpenseCommand}"
                    ToolTip.Tip="记支出">
                <TextBlock Text="+" FontSize="28" Foreground="White" FontWeight="Bold" />
            </Button>
        </StackPanel>

        <Border Grid.Row="0" IsVisible="{Binding ShowAddForm, FallbackValue=False}"
                Background="#B0000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Width="340" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    CornerRadius="16" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <views:AddTransactionView x:Name="AddForm" />
            </Border>
        </Border>
    </Grid>

</UserControl>

